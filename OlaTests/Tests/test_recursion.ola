import std.assert;

int Factorial(int n)
{
    if (n <= 1) return 1;
    return n * Factorial(n - 1);
}

void TestFactorial()
{
    Assert(Factorial(0) == 1);
    Assert(Factorial(1) == 1);
    Assert(Factorial(5) == 120);
    Assert(Factorial(6) == 720);
}

int Fibonacci(int n)
{
    if (n <= 0) return 0;
    if (n == 1) return 1;
    return Fibonacci(n - 1) + Fibonacci(n - 2);
}

void TestFibonacci()
{
    Assert(Fibonacci(0) == 0);
    Assert(Fibonacci(1) == 1);
    Assert(Fibonacci(2) == 1);
    Assert(Fibonacci(7) == 13);
    Assert(Fibonacci(10) == 55);
}

int SumRange(int n)
{
    if (n <= 0) return 0;
    return n + SumRange(n - 1);
}

void TestSumRange()
{
    Assert(SumRange(0) == 0);
    Assert(SumRange(1) == 1);
    Assert(SumRange(5) == 15);
    Assert(SumRange(10) == 55);
}

int Power(int base, int exp)
{
    if (exp == 0) return 1;
    return base * Power(base, exp - 1);
}

void TestPower()
{
    Assert(Power(2, 0) == 1);
    Assert(Power(2, 1) == 2);
    Assert(Power(2, 10) == 1024);
    Assert(Power(3, 4) == 81);
}

int GCD(int a, int b)
{
    if (b == 0) return a;
    return GCD(b, a % b);
}

void TestGCD()
{
    Assert(GCD(12, 8) == 4);
    Assert(GCD(100, 75) == 25);
    Assert(GCD(17, 13) == 1);
    Assert(GCD(0, 5) == 5);
}

bool IsPalindrome(int[10] arr, int left, int right)
{
    if (left >= right) return true;
    if (arr[left] != arr[right]) return false;
    return IsPalindrome(arr, left + 1, right - 1);
}

void TestIsPalindrome()
{
    int[10] pal = {1, 2, 3, 2, 1, 0, 0, 0, 0, 0};
    Assert(IsPalindrome(pal, 0, 4) == true);

    int[10] notpal = {1, 2, 3, 4, 5, 0, 0, 0, 0, 0};
    Assert(IsPalindrome(notpal, 0, 4) == false);
}

public int main()
{
    TestFactorial();
    TestFibonacci();
    TestSumRange();
    TestPower();
    TestGCD();
    TestIsPalindrome();
    return 0;
}
