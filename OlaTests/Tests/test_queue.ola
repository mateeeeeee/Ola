import std.assert;
import std.queue;

void TestPushFront()
{
	Queue<int> q;
	Assert(q.Empty() == true);
	q.Push(10);
	q.Push(20);
	q.Push(30);
	Assert(q.Size() == 3);
	Assert(q.Front() == 10);
	Assert(q.Back() == 30);
	q.Clear();
}

void TestPop()
{
	Queue<int> q;
	q.Push(1);
	q.Push(2);
	q.Push(3);
	q.Pop();
	Assert(q.Size() == 2);
	Assert(q.Front() == 2);
	q.Pop();
	Assert(q.Front() == 3);
	q.Pop();
	Assert(q.Empty() == true);
}

void TestFIFO()
{
	Queue<int> q;
	q.Push(100);
	q.Push(200);
	q.Push(300);
	Assert(q.Front() == 100);
	q.Pop();
	Assert(q.Front() == 200);
	q.Pop();
	Assert(q.Front() == 300);
	q.Pop();
	Assert(q.Empty() == true);
}

void TestWrapAround()
{
	Queue<int> q;
	q.Push(1);
	q.Push(2);
	q.Push(3);
	q.Push(4);
	q.Pop();
	q.Pop();
	q.Push(5);
	q.Push(6);
	Assert(q.Size() == 4);
	Assert(q.Front() == 3);
	Assert(q.Back() == 6);
	q.Clear();
}

public int main()
{
	TestPushFront();
	TestPop();
	TestFIFO();
	TestWrapAround();
	return 0;
}
