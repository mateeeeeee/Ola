import std.assert;
import std.hash;
import std.set;

void TestInsertContains()
{
	Set<int> s;
	Assert(s.Empty() == true);
	Assert(s.Size() == 0);
	s.Insert(10);
	s.Insert(20);
	s.Insert(30);
	Assert(s.Size() == 3);
	Assert(s.Contains(10) == true);
	Assert(s.Contains(20) == true);
	Assert(s.Contains(30) == true);
	Assert(s.Contains(40) == false);
	s.Clear();
}

void TestDuplicates()
{
	Set<int> s;
	Assert(s.Insert(5) == true);
	Assert(s.Insert(5) == false);
	Assert(s.Size() == 1);
	s.Clear();
}

void TestRemove()
{
	Set<int> s;
	s.Insert(1);
	s.Insert(2);
	s.Insert(3);
	Assert(s.Remove(2) == true);
	Assert(s.Size() == 2);
	Assert(s.Contains(2) == false);
	Assert(s.Contains(1) == true);
	Assert(s.Contains(3) == true);
	Assert(s.Remove(2) == false);
	s.Clear();
}

void TestRehash()
{
	Set<int> s;
	int i = 0;
	for(; i < 15; ++i)
	{
		s.Insert(i);
	}
	Assert(s.Size() == 15);
	for(i = 0; i < 15; ++i)
	{
		Assert(s.Contains(i) == true);
	}
	s.Clear();
}

public int main()
{
	TestInsertContains();
	TestDuplicates();
	TestRemove();
	TestRehash();
	return 0;
}
