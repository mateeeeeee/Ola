import std.assert;

void TestPtrBasic()
{
	int* p = alloc(int, 1);
	p[0] = 42;
	Assert(p[0] == 42);
	free(p);
}

void TestPtrNull()
{
	int* p = null;
	Assert(p == null);

	p = alloc(int, 1);
	Assert(p != null);
	p[0] = 10;
	Assert(p[0] == 10);
	free(p);
}

void TestPtrArray()
{
	int* arr = alloc(int, 5);
	int i = 0;
	for(; i < 5; ++i)
	{
		arr[i] = i * i;
	}
	Assert(arr[0] == 0);
	Assert(arr[1] == 1);
	Assert(arr[2] == 4);
	Assert(arr[3] == 9);
	Assert(arr[4] == 16);
	free(arr);
}

void SetValue(int* p, int val)
{
	p[0] = val;
}

int GetValue(int* p)
{
	return p[0];
}

void TestPtrPassToFunction()
{
	int* p = alloc(int, 1);
	SetValue(p, 99);
	Assert(GetValue(p) == 99);
	free(p);
}

int* AllocAndInit(int count, int val)
{
	int* p = alloc(int, count);
	int i = 0;
	for(; i < count; ++i)
	{
		p[i] = val;
	}
	return p;
}

void TestPtrReturn()
{
	int* p = AllocAndInit(3, 7);
	Assert(p[0] == 7);
	Assert(p[1] == 7);
	Assert(p[2] == 7);
	free(p);
}

void TestPtrCompare()
{
	int* a = alloc(int, 1);
	int* b = alloc(int, 1);
	int* c = a;

	Assert(a == c);
	Assert(a != b);
	Assert(a != null);
	Assert(null == null);

	free(a);
	free(b);
}

public int main()
{
	TestPtrBasic();
	TestPtrNull();
	TestPtrArray();
	TestPtrPassToFunction();
	TestPtrReturn();
	TestPtrCompare();
	return 0;
}
