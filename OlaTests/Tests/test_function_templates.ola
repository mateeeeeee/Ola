import std.assert;

T Identity<T>(T x)
{
	return x;
}

T Add<T>(T a, T b)
{
	T result = a + b;
	return result;
}

T Max<T>(T a, T b)
{
	if (a > b) return a;
	return b;
}

T Min<T>(T a, T b)
{
	if (a < b) return a;
	return b;
}

bool IsPositive<T>(T x)
{
	return x > 0;
}

A First<A, B>(A a, B b)
{
	return a;
}

B Second<A, B>(A a, B b)
{
	return b;
}

public int main()
{
	// basic identity
	Assert(Identity<int>(42) == 42);
	Assert(Identity<float>(3.14) == 3.14);
	Assert(Identity<bool>(true) == true);
	Assert(Identity<char>('A') == 'A');

	// arithmetic
	Assert(Add<int>(10, 20) == 30);
	Assert(Add<float>(1.5, 2.5) == 4.0);

	// comparison-based
	Assert(Max<int>(3, 7) == 7);
	Assert(Max<int>(10, 5) == 10);
	Assert(Max<float>(1.1, 2.2) == 2.2);

	Assert(Min<int>(3, 7) == 3);
	Assert(Min<float>(1.1, 2.2) == 1.1);

	// known return type
	Assert(IsPositive<int>(5) == true);
	Assert(IsPositive<int>(-3) == false);
	Assert(IsPositive<float>(0.1) == true);

	// multiple type params
	Assert(First<int, float>(10, 3.14) == 10);
	Assert(Second<int, float>(10, 3.14) == 3.14);

	// cache deduplication: same instantiation used multiple times
	int a = Identity<int>(1);
	int b = Identity<int>(2);
	int c = Identity<int>(3);
	Assert(a + b + c == 6);

	// use in expressions
	int sum = Add<int>(Max<int>(1, 2), Min<int>(3, 4));
	Assert(sum == 5);

	// assign to variable
	float maxf = Max<float>(10.0, 20.0);
	Assert(maxf == 20.0);

	return 0;
}
