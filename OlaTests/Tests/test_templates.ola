import std.assert;

class Box<T>
{
	Box(T v)
	{
		this.value = v;
	}
	public T GetValue() const
	{
		return this.value;
	}
	public void SetValue(T v)
	{
		this.value = v;
	}
	private T value;
};

class Pair<A, B>
{
	Pair(A a, B b)
	{
		this.first = a;
		this.second = b;
	}
	public A GetFirst() const { return this.first; }
	public B GetSecond() const { return this.second; }
	private A first;
	private B second;
};

class Counter<T>
{
	Counter(T initial)
	{
		this.val = initial;
		this.count = 0;
	}
	public void Set(T v)
	{
		this.val = v;
		this.count = this.count + 1;
	}
	public T Get() const { return this.val; }
	public int GetCount() const { return this.count; }
	private T val;
	private int count;
};

class Node<T>
{
	Node(T val) { this.data = val; this.next = null; }
	public T data;
	public Node<T>* next;
};

class List<T>
{
	List() { this.head = null; }
	public Node<T>* head;
};

public int main()
{
	Box<int> bi(42);
	Assert(bi.GetValue() == 42);
	bi.SetValue(100);
	Assert(bi.GetValue() == 100);

	Box<float> bf(3.14);
	Assert(bf.GetValue() == 3.14);
	bf.SetValue(2.71);
	Assert(bf.GetValue() == 2.71);

	Box<bool> bb(true);
	Assert(bb.GetValue() == true);
	bb.SetValue(false);
	Assert(bb.GetValue() == false);

	Box<int> bi2(10);
	Assert(bi2.GetValue() == 10);

	Pair<int, float> p1(10, 3.14);
	Assert(p1.GetFirst() == 10);
	Assert(p1.GetSecond() == 3.14);

	Pair<bool, int> p2(true, 99);
	Assert(p2.GetFirst() == true);
	Assert(p2.GetSecond() == 99);

	Pair<int, int> p3(1, 2);
	Assert(p3.GetFirst() == 1);
	Assert(p3.GetSecond() == 2);

	Counter<int> c(0);
	Assert(c.Get() == 0);
	Assert(c.GetCount() == 0);
	c.Set(5);
	Assert(c.Get() == 5);
	Assert(c.GetCount() == 1);
	c.Set(10);
	Assert(c.Get() == 10);
	Assert(c.GetCount() == 2);

	Counter<float> cf(1.0);
	Assert(cf.Get() == 1.0);
	cf.Set(2.5);
	Assert(cf.Get() == 2.5);
	Assert(cf.GetCount() == 1);

	Node<int>* na = new Node<int>(10);
	Node<int>* nb = new Node<int>(20);
	Node<int>* nc = new Node<int>(30);
	na->next = nb;
	nb->next = nc;
	Assert(na->data == 10);
	Assert(na->next->data == 20);
	Assert(na->next->next->data == 30);
	Assert(na->next->next->next == null);

	List<int> list;
	Assert(list.head == null);
	list.head = na;
	Assert(list.head->data == 10);
	Assert(list.head->next->data == 20);
	Assert(list.head->next->next->data == 30);

	delete nc;
	delete nb;
	delete na;

	return 0;
}
