import std.assert;

// Variable shifts on x86 must use the CL register (low 8 bits of RCX).
// The shift count gets moved to RCX; any vreg also live in RCX at that
// moment would be clobbered. This stresses RCX liveness across shifts.
// `public` prevents IPCP from folding away the work.

public int ShiftMix(int a, int b, int c, int d, int sh1, int sh2, int sh3, int sh4)
{
    // Many distinct shifts where prior shift results stay live across later
    // shifts. Each shift puts the count into CL; the previous results must
    // not have been allocated to RCX.
    int s1 = a << sh1;
    int s2 = b << sh2;
    int s3 = c << sh3;
    int s4 = d << sh4;

    int r1 = (a + 1) >> sh1;
    int r2 = (b + 1) >> sh2;
    int r3 = (c + 1) >> sh3;
    int r4 = (d + 1) >> sh4;

    // Combine — every intermediate above must still be holding the right value.
    int t1 = (s1 + s2) << ((sh1 + sh2) & 7);
    int t2 = (s3 + s4) >> ((sh3 + sh4) & 7);
    int t3 = (r1 + r3) << (sh2 & 7);
    int t4 = (r2 + r4) >> (sh1 & 7);

    return s1 + s2 + s3 + s4 + r1 + r2 + r3 + r4 + t1 + t2 + t3 + t4;
}

public int PowerOfTwoSum(int n)
{
    // Accumulate sum of 2^i for i in [0, n).
    int total = 0;
    int i = 0;
    while (i < n)
    {
        int v = 1 << i;
        total = total + v;
        i = i + 1;
    }
    return total;
}

public int RotateLikePattern(int x, int k)
{
    // Simulated rotate: combine left and right shifts, with both shift counts
    // requiring CL. Tests that values surviving the first shift aren't
    // allocated to RCX.
    int hi = x << k;
    int lo = x >> (8 - k);
    int merged = hi | lo;
    int again = merged << (k & 3);
    return again ^ x;
}

public int main()
{
    int r1 = ShiftMix(3, 5, 7, 11, 2, 3, 1, 4);
    // s1=12, s2=40, s3=14, s4=176
    // r1=4>>2=1, r2=6>>3=0, r3=8>>1=4, r4=12>>4=0
    // t1=(12+40)<<((2+3)&7)=52<<5=1664
    // t2=(14+176)>>((1+4)&7)=190>>5=5
    // t3=(1+4)<<(3&7)=5<<3=40
    // t4=(0+0)>>(2&7)=0
    // sum = 12+40+14+176+1+0+4+0+1664+5+40+0 = 1956
    Assert(r1 == 1956);

    Assert(PowerOfTwoSum(0) == 0);
    Assert(PowerOfTwoSum(1) == 1);
    Assert(PowerOfTwoSum(4) == 15);
    Assert(PowerOfTwoSum(8) == 255);
    Assert(PowerOfTwoSum(10) == 1023);

    // RotateLikePattern: just ensure it returns deterministic values, not
    // wrong-due-to-RA-clobber values.
    int rot1 = RotateLikePattern(5, 2);
    int rot2 = RotateLikePattern(5, 2);
    Assert(rot1 == rot2);

    int rot3 = RotateLikePattern(13, 3);
    int rot4 = RotateLikePattern(13, 3);
    Assert(rot3 == rot4);

    return 0;
}
