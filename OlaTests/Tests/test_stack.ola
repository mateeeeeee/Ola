import std.assert;
import std.stack;

void TestPushTop()
{
	Stack<int> s;
	Assert(s.Empty() == true);
	s.Push(10);
	s.Push(20);
	s.Push(30);
	Assert(s.Size() == 3);
	Assert(s.Top() == 30);
	s.Clear();
}

void TestPop()
{
	Stack<int> s;
	s.Push(1);
	s.Push(2);
	s.Push(3);
	s.Pop();
	Assert(s.Size() == 2);
	Assert(s.Top() == 2);
	s.Pop();
	Assert(s.Top() == 1);
	s.Pop();
	Assert(s.Empty() == true);
}

void TestLIFO()
{
	Stack<int> s;
	s.Push(100);
	s.Push(200);
	s.Push(300);
	Assert(s.Top() == 300);
	s.Pop();
	Assert(s.Top() == 200);
	s.Pop();
	Assert(s.Top() == 100);
	s.Pop();
	Assert(s.Empty() == true);
}

public int main()
{
	TestPushTop();
	TestPop();
	TestLIFO();
	return 0;
}
