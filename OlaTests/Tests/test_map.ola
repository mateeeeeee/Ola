import std.assert;
import std.hash;
import std.map;

void TestPutGet()
{
	Map<int, int> m;
	Assert(m.Empty() == true);
	m.Put(1, 100);
	m.Put(2, 200);
	m.Put(3, 300);
	Assert(m.Size() == 3);
	Assert(m.Get(1) == 100);
	Assert(m.Get(2) == 200);
	Assert(m.Get(3) == 300);
	m.Clear();
}

void TestOverwrite()
{
	Map<int, int> m;
	m.Put(1, 10);
	Assert(m.Get(1) == 10);
	m.Put(1, 20);
	Assert(m.Get(1) == 20);
	Assert(m.Size() == 1);
	m.Clear();
}

void TestContains()
{
	Map<int, int> m;
	m.Put(5, 50);
	Assert(m.Contains(5) == true);
	Assert(m.Contains(6) == false);
	m.Clear();
}

void TestRemove()
{
	Map<int, int> m;
	m.Put(1, 10);
	m.Put(2, 20);
	m.Put(3, 30);
	Assert(m.Remove(2) == true);
	Assert(m.Size() == 2);
	Assert(m.Contains(2) == false);
	Assert(m.Get(1) == 10);
	Assert(m.Get(3) == 30);
	Assert(m.Remove(2) == false);
	m.Clear();
}

void TestRehash()
{
	Map<int, int> m;
	int i = 0;
	for(; i < 15; ++i)
	{
		m.Put(i, i * 10);
	}
	Assert(m.Size() == 15);
	int j = 0;
	for(; j < 15; ++j)
	{
		Assert(m.Get(j) == j * 10);
	}
	m.Clear();
}

public int main()
{
	TestPutGet();
	TestOverwrite();
	TestContains();
	TestRemove();
	TestRehash();
	return 0;
}
