define internal @TestIncrementInExpressions void() {
entry:
%0 = alloca ptr
store 5, ptr %0
%1 = load i64, ptr %0
%2 = add i64 %1, 10
%3 = icmp eq i64 %2, 15
call i8 %3, @Assert
call i8 1, @Assert
call i8 1, @Assert
call i8 1, @Assert
%4 = alloca ptr
store 10, ptr %4
%5 = load i64, ptr %4
%6 = sub i64 %5, 5
%7 = icmp eq i64 %6, 5
call i8 %7, @Assert
call i8 1, @Assert
br label exit
exit:
ret 
}


