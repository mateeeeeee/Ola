define internal @TestWhileLoopFloatCondition void() {
entry:
br label while.cond
while.cond:
%0 = phi f64 [ 0, entry ], [ %1, while.body ]
%2 = phi f64 [ 0.1, entry ], [ %3, while.body ]
%4 = fcmp olt f64 %2, 0.99
br i8 %4, label while.body, label while.end
while.body:
%1 = fadd f64 %0, %2
%3 = fadd f64 %2, 0.1
br label while.cond
while.end:
%5 = fcmp ogt f64 %0, 4.49
%6 = fcmp olt f64 %0, 4.51
%7 = and i8 %5, %6
%8 = icmp ne i8 %7, 0
call i8 %8, @Assert
br label exit
exit:
ret 
}


