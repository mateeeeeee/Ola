define internal @TestPtrPassToFunction void() {
entry:
%0 = call i64 8, @__ola_alloc
%1 = bitcast ptr %0
br label entry.inlined
entry.split.split:
%2 = icmp eq i64 %3, 99
call i8 %2, @Assert
