}


define internal @TestPtrCompare void() {
entry:
%0 = call i64 8, @__ola_alloc
%1 = bitcast ptr %0
%2 = call i64 8, @__ola_alloc
%3 = bitcast ptr %2
%4 = icmp eq ptr %1, %1
call i8 %4, @Assert
%5 = icmp ne ptr %1, %3
call i8 %5, @Assert
%6 = icmp ne ptr %1, null
call i8 %6, @Assert
%7 = icmp eq ptr null, null
call i8 %7, @Assert
%8 = bitcast ptr %1
call ptr %8, @__ola_free
%9 = bitcast ptr %3
call ptr %9, @__ola_free
br label exit
exit:
ret 
}


