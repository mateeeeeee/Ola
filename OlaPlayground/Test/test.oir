Module ID : test.ola

declare @Assert void(i8)


declare @AssertMsg void(i8,ptr)


define internal @Factorial__I i64(i64 %n) {
entry:
%0 = icmp sle i64 %n, 1
br i8 %0, label if.then, label if.end
if.then:
br label exit
if.end:
%1 = sub i64 %n, 1
%2 = call i64 %1, @Factorial__I
%3 = smul i64 %n, %2
br label exit
exit:
%4 = phi i64 [ %3, if.end ], [ 1, if.then ]
ret i64 %4
}


define internal @TestFactorial void() {
entry:
%0 = call i64 0, @Factorial__I
%1 = icmp eq i64 %0, 1
call i8 %1, @Assert
%2 = call i64 1, @Factorial__I
%3 = icmp eq i64 %2, 1
call i8 %3, @Assert
%4 = call i64 5, @Factorial__I
%5 = icmp eq i64 %4, 120
call i8 %5, @Assert
%6 = call i64 6, @Factorial__I
%7 = icmp eq i64 %6, 720
call i8 %7, @Assert
br label exit
exit:
ret 
}


define internal @Fibonacci__I i64(i64 %n) {
entry:
%0 = icmp sle i64 %n, 0
br i8 %0, label if.then, label if.end
if.then:
br label exit
if.end:
%1 = icmp eq i64 %n, 1
br i8 %1, label if.then1, label if.end1
if.then1:
br label exit
if.end1:
%2 = sub i64 %n, 1
%3 = call i64 %2, @Fibonacci__I
%4 = sub i64 %n, 2
%5 = call i64 %4, @Fibonacci__I
%6 = add i64 %3, %5
br label exit
exit:
%7 = phi i64 [ %6, if.end1 ], [ 1, if.then1 ], [ 0, if.then ]
ret i64 %7
}


define internal @TestFibonacci void() {
entry:
%0 = call i64 0, @Fibonacci__I
%1 = icmp eq i64 %0, 0
call i8 %1, @Assert
%2 = call i64 1, @Fibonacci__I
%3 = icmp eq i64 %2, 1
call i8 %3, @Assert
