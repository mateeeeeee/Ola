Module ID : test.ola

define internal @factorial_helper__I__I i64(i64 %n,i64 %acc) {
entry:
br label tailrecurse
tailrecurse:
%acc.tr = phi i64 [ %acc, entry ], [ %0, if.end ]
%n.tr = phi i64 [ %n, entry ], [ %1, if.end ]
%2 = icmp sle i64 %n.tr, 1
br i8 %2, label if.then, label if.end
if.then:
br label exit
if.end:
%1 = sub i64 %n.tr, 1
%0 = smul i64 %n.tr, %acc.tr
br label tailrecurse
exit:
ret i64 %acc.tr
}


define internal @factorial__I i64(i64 %n) {
entry:
%0 = call i64 5, 1, @factorial_helper__I__I
br label exit
exit:
ret i64 %0
}


define external @main i64() {
entry:
%0 = call i64 5, @factorial__I
br label exit
exit:
ret i64 %0
}

