call i8 %6, @Assert
%7 = load ptr, ptr %0
%8 = ptr add ptr %7, 0
store 10, ptr %8
%9 = load ptr, ptr %0
%10 = ptr add ptr %9, 0
%11 = load i64, ptr %10
%12 = icmp eq i64 %11, 10
call i8 %12, @Assert
%13 = load ptr, ptr %0
%14 = bitcast ptr %13
call ptr %14, @__ola_free
br label exit
exit:
ret 
}


define internal @TestPtrArray void() {
