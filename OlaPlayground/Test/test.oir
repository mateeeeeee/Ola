define internal @TestPtrNull void() {
entry:
%0 = alloca i64
%1 = alloca ptr
store null, ptr %1
%2 = load ptr, ptr %1
%3 = icmp eq ptr %2, null
call i8 %3, @Assert
store ptr %0, ptr %1
%4 = load ptr, ptr %1
%5 = icmp ne ptr %4, null
call i8 %5, @Assert
%6 = load ptr, ptr %1
%7 = ptr add ptr %6, 0
store 10, ptr %7
%8 = load ptr, ptr %1
%9 = ptr add ptr %8, 0
%10 = load i64, ptr %9
%11 = icmp eq i64 %10, 10
call i8 %11, @Assert
br label exit
exit:
ret 
}


