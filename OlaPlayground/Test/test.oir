%4 = ptr add ptr %0, 24
store 2, ptr %4
%5 = ptr add ptr %0, 32
store 1, ptr %5
br label while.cond
while.cond:
%6 = phi i64 [ 0, entry ], [ %7, while.body ]
%8 = phi i64 [ 0, entry ], [ %9, while.body ]
%10 = icmp slt i64 %8, 5
br i8 %10, label while.body, label while.end
while.body:
%11 = gep ptr %0, 0, %8
%12 = load i64, ptr %11
%7 = add i64 %6, %12
%13 = alloca ptr
store i64 %8, ptr %13
%9 = add i64 %8, 1
br label while.cond
while.end:
%14 = icmp eq i64 %6, 15
call i8 %14, @Assert
br label while.cond1
while.cond1:
%15 = phi i64 [ 0, while.end ], [ %16, if.end ]
%17 = icmp slt i64 %15, 5
br i8 %17, label while.body1, label edge.0
edge.0:
br label while.end1
while.body1:
%18 = gep ptr %0, 0, %15
%19 = load i64, ptr %18
%20 = srem i64 %19, 2
%21 = icmp eq i64 %20, 0
br i8 %21, label edge.1, label if.end
edge.1:
br label while.end1
while.end1:
%22 = gep ptr %0, 0, %15
%23 = load i64, ptr %22
%24 = icmp eq i64 %23, 4
call i8 %24, @Assert
br label exit
if.end:
%25 = alloca ptr
store i64 %15, ptr %25
%16 = add i64 %15, 1
br label while.cond1
exit:
ret 
}


