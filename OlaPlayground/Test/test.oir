Module ID : test.ola

declare @Assert void(i8)


declare @AssertMsg void(i8,ptr)


define internal @TestPtrBasic void() {
entry:
%0 = call i64 8, @__ola_alloc
%1 = bitcast ptr %0
%2 = alloca ptr
store ptr %1, ptr %2
%3 = load ptr, ptr %2
%4 = ptr add ptr %3, 0
store 42, ptr %4
%5 = load ptr, ptr %2
%6 = ptr add ptr %5, 0
%7 = load i64, ptr %6
%8 = icmp eq i64 %7, 42
call i8 %8, @Assert
%9 = load ptr, ptr %2
%10 = bitcast ptr %9
call ptr %10, @__ola_free
br label exit
exit:
ret 
}


declare @__ola_alloc ptr(i64)


declare @__ola_free void(ptr)


define internal @TestPtrNull void() {
entry:
