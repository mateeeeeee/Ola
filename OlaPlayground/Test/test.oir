}


define external @Vector.float.$Destroy void(ptr %this) {
entry:
%0 = ptr add ptr %this, 0
%1 = load ptr, ptr %0
%2 = icmp ne ptr %1, null
br i8 %2, label if.then, label edge.0
edge.0:
br label if.end
if.then:
%3 = load ptr, ptr %0
%4 = bitcast ptr %3
call ptr %4, @__ola_delete
br label if.end
if.end:
store null, ptr %0
%5 = ptr add ptr %this, 8
store 0, ptr %5
%6 = ptr add ptr %this, 16
store 0, ptr %6
br label exit
exit:
ret 
}


