define internal @AllocAndInit__I__I ptr(i64 %count,i64 %val) {
entry:
%0 = alloca i64
store i64 %count, ptr %0
%1 = alloca i64
store i64 %val, ptr %1
%2 = alloca ptr
%3 = load i64, ptr %0
%4 = smul i64 %3, 8
%5 = call i64 %4, @__ola_alloc
%6 = bitcast ptr %5
%7 = alloca ptr
store ptr %6, ptr %7
%8 = alloca i64
store 0, ptr %8
br label for.cond
for.body:
%9 = load i64, ptr %8
%10 = load ptr, ptr %7
%11 = gep ptr %10, %9
%12 = load i64, ptr %1
store i64 %12, ptr %11
br label for.iter
for.cond:
%13 = load i64, ptr %8
%14 = load i64, ptr %0
%15 = icmp slt i64 %13, %14
br i8 %15, label for.body, label for.end
for.iter:
%16 = load i64, ptr %8
%17 = add i64 %16, 1
store i64 %17, ptr %8
br label for.cond
for.end:
%18 = load ptr, ptr %7
store ptr %18, ptr %2
br label exit
return:
br label exit
exit:
%19 = load ptr, ptr %2
ret ptr %19
}


