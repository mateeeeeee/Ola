Module ID : test.ola

declare @Assert void(i8)


declare @AssertMsg void(i8,ptr)


define internal @GlobalInt1 ptr 5


define internal @GlobalInt2 ptr 10


define internal @TestIntIncrementDecrement void() {
entry:
call i8 1, @Assert
call i8 1, @Assert
call i8 1, @Assert
call i8 1, @Assert
%0 = alloca ptr
store 10, ptr %0
%1 = alloca i64
%2 = load ptr, ptr %0
store ptr %2, ptr %1
%3 = load i64, ptr %1
%4 = icmp eq i64 %3, 10
call i8 %4, @Assert
call i8 1, @Assert
%5 = alloca ptr
store 15, ptr %5
%6 = alloca i64
%7 = load ptr, ptr %5
store ptr %7, ptr %6
%8 = load i64, ptr %6
%9 = icmp eq i64 %8, 15
call i8 %9, @Assert
call i8 1, @Assert
%10 = load i64, ptr @GlobalInt1
%11 = add i64 %10, 1
store i64 %11, ptr @GlobalInt1
%12 = icmp eq i64 %11, 6
call i8 %12, @Assert
%13 = load i64, ptr @GlobalInt1
%14 = icmp eq i64 %13, 6
call i8 %14, @Assert
%15 = load i64, ptr @GlobalInt2
%16 = sub i64 %15, 1
store i64 %16, ptr @GlobalInt2
%17 = icmp eq i64 %16, 9
call i8 %17, @Assert
%18 = load i64, ptr @GlobalInt2
%19 = icmp eq i64 %18, 9
call i8 %19, @Assert
%20 = load i64, ptr @GlobalInt1
%21 = alloca ptr
store i64 %20, ptr %21
%22 = add i64 %20, 1
store i64 %22, ptr @GlobalInt1
%23 = alloca i64
%24 = load ptr, ptr %21
store ptr %24, ptr %23
%25 = load i64, ptr %23
%26 = icmp eq i64 %25, 6
call i8 %26, @Assert
%27 = load i64, ptr @GlobalInt1
%28 = icmp eq i64 %27, 7
call i8 %28, @Assert
%29 = load i64, ptr @GlobalInt2
%30 = alloca ptr
store i64 %29, ptr %30
%31 = sub i64 %29, 1
store i64 %31, ptr @GlobalInt2
%32 = alloca i64
%33 = load ptr, ptr %30
store ptr %33, ptr %32
%34 = load i64, ptr %32
%35 = icmp eq i64 %34, 9
call i8 %35, @Assert
%36 = load i64, ptr @GlobalInt2
%37 = icmp eq i64 %36, 8
call i8 %37, @Assert
br label exit
exit:
ret 
}


define internal @GlobalFloat1 ptr 3.5


define internal @GlobalFloat2 ptr 8.5


define internal @TestFloatIncrementDecrement void() {
entry:
call i8 1, @Assert
call i8 1, @Assert
call i8 1, @Assert
call i8 1, @Assert
%0 = alloca ptr
store 6.5, ptr %0
%1 = alloca f64
%2 = load ptr, ptr %0
store ptr %2, ptr %1
%3 = load f64, ptr %1
%4 = fcmp oeq f64 %3, 6.5
call i8 %4, @Assert
call i8 1, @Assert
%5 = alloca ptr
store 12.5, ptr %5
%6 = alloca f64
%7 = load ptr, ptr %5
store ptr %7, ptr %6
%8 = load f64, ptr %6
%9 = fcmp oeq f64 %8, 12.5
call i8 %9, @Assert
call i8 1, @Assert
%10 = load f64, ptr @GlobalFloat1
%11 = alloca ptr
store f64 %10, ptr %11
%12 = fadd f64 %10, 1
store f64 %12, ptr @GlobalFloat1
%13 = alloca f64
%14 = load ptr, ptr %11
store ptr %14, ptr %13
%15 = load f64, ptr %13
%16 = fcmp oeq f64 %15, 3.5
call i8 %16, @Assert
%17 = load f64, ptr @GlobalFloat1
%18 = fcmp oeq f64 %17, 4.5
call i8 %18, @Assert
%19 = load f64, ptr @GlobalFloat2
%20 = alloca ptr
store f64 %19, ptr %20
%21 = fsub f64 %19, 1
store f64 %21, ptr @GlobalFloat2
%22 = alloca f64
%23 = load ptr, ptr %20
store ptr %23, ptr %22
%24 = load f64, ptr %22
%25 = fcmp oeq f64 %24, 8.5
call i8 %25, @Assert
%26 = load f64, ptr @GlobalFloat2
%27 = fcmp oeq f64 %26, 7.5
call i8 %27, @Assert
br label exit
exit:
ret 
}


define internal @TestIncrementInLoop void() {
entry:
br label for.cond
for.body:
%0 = alloca ptr
store i64 %1, ptr %0
%2 = add i64 %1, 1
br label for.iter
for.cond:
%1 = phi i64 [ 0, entry ], [ %2, for.iter ]
%3 = phi i64 [ 0, entry ], [ %4, for.iter ]
%5 = icmp slt i64 %3, 5
br i8 %5, label for.body, label for.end
for.iter:
%6 = alloca ptr
store i64 %3, ptr %6
%4 = add i64 %3, 1
br label for.cond
for.end:
%7 = icmp eq i64 %1, 5
call i8 %7, @Assert
br label while.cond
while.cond:
%8 = phi i64 [ 0, for.end ], [ %9, while.body ]
%10 = phi i64 [ 0, for.end ], [ %11, while.body ]
%12 = icmp slt i64 %10, 5
br i8 %12, label while.body, label while.end
while.body:
%13 = alloca ptr
store i64 %10, ptr %13
%11 = add i64 %10, 1
%14 = load i64, ptr %13
%9 = add i64 %8, %14
br label while.cond
while.end:
%15 = icmp eq i64 %8, 10
call i8 %15, @Assert
%16 = icmp eq i64 %10, 5
call i8 %16, @Assert
br label exit
exit:
ret 
}


define internal @TestMultipleIncrements void() {
entry:
%0 = alloca ptr
store 0, ptr %0
