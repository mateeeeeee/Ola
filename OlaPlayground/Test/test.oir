define external @Vector.float.$Back f64(ptr %this) {
entry:
%0 = ptr add ptr %this, 0
%1 = ptr add ptr %this, 8
%2 = load i64, ptr %1
%3 = sub i64 %2, 1
%4 = load ptr, ptr %0
%5 = gep ptr %4, %3
%6 = load f64, ptr %5
