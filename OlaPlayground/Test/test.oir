br label while.cond
exit:
ret 
}


define internal @TestWhileLoopWithContinue void() {
entry:
br label while.cond
while.cond:
%0 = phi i64 [ 0, entry ], [ %1, loop.latch ]
%2 = phi i64 [ 0, entry ], [ %3, loop.latch ]
%4 = icmp slt i64 %2, 5
br i8 %4, label while.body, label while.end
while.body:
%5 = alloca ptr
store i64 %2, ptr %5
%6 = add i64 %2, 1
%7 = srem i64 %6, 2
%8 = icmp eq i64 %7, 0
br i8 %8, label if.then, label edge.0
edge.0:
br label loop.latch
while.end:
%9 = icmp eq i64 %0, 9
call i8 %9, @Assert
br label exit
if.then:
%10 = add i64 %0, %6
br label loop.latch
loop.latch:
%3 = phi i64 [ %6, loop.latch ], [ %6, if.then ]
%1 = phi i64 [ %10, loop.latch ], [ %0, if.then ]
br label while.cond
exit:
ret 
}


define internal @TestWhileLoopMultipleExits void() {
entry:
br label while.cond
while.cond:
%0 = phi i64 [ 0, entry ], [ %1, if.end ]
%2 = phi i8 [ 0, entry ], [ %3, if.end ]
%4 = icmp slt i64 %0, 5
%5 = icmp eq i8 %2, 0
%6 = and i8 %4, %5
%7 = icmp ne i8 %6, 0
br i8 %7, label while.body, label while.end
while.body:
%8 = alloca ptr
store i64 %0, ptr %8
%1 = add i64 %0, 1
%9 = icmp eq i64 %1, 3
br i8 %9, label if.then, label edge.0
edge.0:
br label if.end
while.end:
%10 = icmp eq i64 %0, 3
call i8 %10, @Assert
call i8 %2, @Assert
br label exit
if.then:
br label if.end
if.end:
%3 = phi i8 [ %2, edge.0 ], [ 1, if.then ]
br label while.cond
exit:
ret 
}


