}


define external @Vector.float.$PushBack__F void(ptr %this,f64 %value) {
entry:
%0 = ptr add ptr %this, 8
%1 = ptr add ptr %this, 16
%2 = load i64, ptr %0
%3 = load i64, ptr %1
%4 = icmp slt i64 %2, %3
br i8 %4, label if.then, label if.end
if.then:
%5 = ptr add ptr %this, 0
%6 = load i64, ptr %0
%7 = load ptr, ptr %5
%8 = gep ptr %7, %6
store f64 %value, ptr %8
%9 = load i64, ptr %0
%10 = add i64 %9, 1
store i64 %10, ptr %0
br label exit
if.end:
%11 = load i64, ptr %1
%12 = icmp sgt i64 %11, 0
%13 = load i64, ptr %1
%14 = add i64 %13, %13
%15 = select i8 %12, i64 %14, 4
%16 = shl i64 %15, 3
%17 = call i64 %16, @__ola_new
%18 = bitcast ptr %17
%19 = ptr add ptr %this, 0
br label for.cond
for.body:
%20 = gep ptr %18, %21
%22 = load ptr, ptr %19
%23 = gep ptr %22, %21
%24 = load f64, ptr %23
store f64 %24, ptr %20
br label for.iter
for.cond:
%21 = phi i64 [ 0, if.end ], [ %25, for.iter ]
%26 = load i64, ptr %0
%27 = icmp slt i64 %21, %26
br i8 %27, label for.body, label for.end
for.iter:
%25 = add i64 %21, 1
br label for.cond
for.end:
%28 = load i64, ptr %0
%29 = gep ptr %18, %28
store f64 %value, ptr %29
%30 = ptr add ptr %this, 0
%31 = load ptr, ptr %30
%32 = icmp ne ptr %31, null
br i8 %32, label if.then1, label edge.0
edge.0:
br label if.end1
if.then1:
%33 = ptr add ptr %this, 0
%34 = load ptr, ptr %33
%35 = bitcast ptr %34
call ptr %35, @__ola_delete
br label if.end1
if.end1:
%36 = ptr add ptr %this, 0
store ptr %18, ptr %36
store i64 %15, ptr %1
%37 = load i64, ptr %0
%38 = add i64 %37, 1
store i64 %38, ptr %0
br label exit
exit:
ret 
}


define external @Vector.float.$PopBack void(ptr %this) {
entry:
%0 = ptr add ptr %this, 8
%1 = load i64, ptr %0
%2 = sub i64 %1, 1
store i64 %2, ptr %0
br label exit
