%2 = alloca ptr
store 2, ptr %2
call i8 1, @Assert
%3 = alloca ptr
store 10, ptr %3
%4 = alloca ptr
store 9, ptr %4
call i8 1, @Assert
call i8 1, @Assert
br label exit
exit:
ret 
}


define internal @TestIncrementNegative void() {
