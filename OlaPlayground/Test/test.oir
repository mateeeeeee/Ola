Module ID : test.ola

declare @Assert void(i8)


declare @AssertMsg void(i8,ptr)


define internal @TestPtrBasic void() {
entry:
%0 = call i64 8, @__ola_alloc
%1 = bitcast ptr %0
%2 = ptr add ptr %1, 0
store 42, ptr %2
%3 = load i64, ptr %2
%4 = icmp eq i64 %3, 42
call i8 %4, @Assert
%5 = bitcast ptr %1
call ptr %5, @__ola_free
br label exit
exit:
ret 
}


declare @__ola_alloc ptr(i64)


declare @__ola_free void(ptr)


define internal @TestPtrNull void() {
entry:
%0 = alloca ptr
store null, ptr %0
%1 = load ptr, ptr %0
%2 = icmp eq ptr %1, null
call i8 %2, @Assert
%3 = call i64 8, @__ola_alloc
%4 = bitcast ptr %3
store ptr %4, ptr %0
%5 = load ptr, ptr %0
%6 = icmp ne ptr %5, null
call i8 %6, @Assert
%7 = load ptr, ptr %0
%8 = ptr add ptr %7, 0
store 10, ptr %8
%9 = load ptr, ptr %0
%10 = ptr add ptr %9, 0
%11 = load i64, ptr %10
%12 = icmp eq i64 %11, 10
call i8 %12, @Assert
%13 = load ptr, ptr %0
%14 = bitcast ptr %13
call ptr %14, @__ola_free
br label exit
exit:
ret 
}


define internal @TestPtrArray void() {
entry:
