}


define internal @AllocAndInit__I__I ptr(i64 %count,i64 %val) {
entry:
%0 = call i64 24, @__ola_alloc
%1 = bitcast ptr %0
%2 = gep ptr %1, 0
store 7, ptr %2
%3 = gep ptr %1, 1
store 7, ptr %3
%4 = gep ptr %1, 2
