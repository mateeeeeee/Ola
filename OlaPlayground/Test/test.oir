br i8 %0, label if.then, label if.end
if.then:
br label exit
if.end:
%1 = sub i64 %exp, 1
%2 = call i64 %base, %1, @Power__I__I
%3 = smul i64 %base, %2
br label exit
exit:
%4 = phi i64 [ %3, if.end ], [ 1, if.then ]
ret i64 %4
}


define internal @TestPower void() {
entry:
