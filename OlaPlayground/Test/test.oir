store 0, ptr %0
%1 = alloca i64
store 1, ptr %1
br label dowhile.body
dowhile.body:
%2 = load i64, ptr %0
%3 = load i64, ptr %1
%4 = add i64 %2, %3
store i64 %4, ptr %0
%5 = load i64, ptr %1
%6 = alloca ptr
store i64 %5, ptr %6
%7 = add i64 %5, 1
store i64 %7, ptr %1
br label dowhile.cond
dowhile.cond:
%8 = load i64, ptr %1
%9 = icmp sle i64 %8, 5
br i8 %9, label dowhile.body, label dowhile.end
dowhile.end:
%10 = load i64, ptr %0
%11 = icmp eq i64 %10, 15
call i8 %11, @Assert
br label exit
exit:
ret 
}


