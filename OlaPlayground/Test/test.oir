define internal @GCD__I__I i64(i64 %a,i64 %b) {
entry:
br label tailrecurse
tailrecurse:
%b.tr = phi i64 [ %b, entry ], [ %0, if.end ]
%a.tr = phi i64 [ %a, entry ], [ %b.tr, if.end ]
%1 = icmp eq i64 %b.tr, 0
br i8 %1, label if.then, label if.end
if.then:
br label exit
if.end:
%0 = srem i64 %a.tr, %b.tr
br label tailrecurse
exit:
ret i64 %a.tr
}


define internal @TestGCD void() {
entry:
%0 = call i64 12, 8, @GCD__I__I
%1 = icmp eq i64 %0, 4
call i8 %1, @Assert
%2 = call i64 100, 75, @GCD__I__I
%3 = icmp eq i64 %2, 25
call i8 %3, @Assert
%4 = call i64 17, 13, @GCD__I__I
%5 = icmp eq i64 %4, 1
call i8 %5, @Assert
%6 = call i64 0, 5, @GCD__I__I
%7 = icmp eq i64 %6, 5
call i8 %7, @Assert
br label exit
exit:
ret 
}


define internal @IsPalindrome__I10__I__I i8(i64[10] %arr,i64 %left,i64 %right) {
entry:
%0 = alloca i64[10]
store i64[10] %arr, ptr %0
%1 = icmp sge i64 %left, %right
br i8 %1, label if.then, label if.end
if.then:
br label exit
if.end:
%2 = gep ptr %0, 0, %left
%3 = gep ptr %0, 0, %right
%4 = load i64, ptr %2
%5 = load i64, ptr %3
%6 = icmp ne i64 %4, %5
br i8 %6, label if.then1, label if.end1
if.then1:
br label exit
if.end1:
%7 = load i64[10], ptr %0
%8 = add i64 %left, 1
%9 = sub i64 %right, 1
%10 = call i64[10] %7, %8, %9, @IsPalindrome__I10__I__I
br label exit
exit:
%11 = phi i8 [ %10, if.end1 ], [ 0, if.then1 ], [ 1, if.then ]
ret i8 %11
}


