Module ID : test.ola

declare @Assert void(i8)


declare @AssertMsg void(i8,ptr)


define internal @TestWhileLoopInt void() {
entry:
br label while.cond
while.cond:
%0 = phi i64 [ 0, entry ], [ %1, while.body ]
%2 = phi i64 [ 1, entry ], [ %3, while.body ]
%4 = icmp sle i64 %2, 5
br i8 %4, label while.body, label while.end
while.body:
%1 = add i64 %0, %2
%5 = alloca ptr
store i64 %2, ptr %5
%3 = add i64 %2, 1
br label while.cond
while.end:
%6 = icmp eq i64 %0, 15
call i8 %6, @Assert
br label exit
exit:
ret 
}


define internal @TestWhileLoopBool void() {
entry:
br label while.cond
while.cond:
%0 = phi i8 [ 1, entry ], [ %1, if.end ]
%2 = phi i64 [ 0, entry ], [ %3, if.end ]
br i8 %0, label while.body, label while.end
while.body:
%4 = alloca ptr
store i64 %2, ptr %4
%3 = add i64 %2, 1
%5 = icmp eq i64 %3, 3
br i8 %5, label if.then, label edge.0
edge.0:
br label if.end
while.end:
%6 = icmp eq i64 %2, 3
call i8 %6, @Assert
br label exit
if.then:
br label if.end
if.end:
%1 = phi i8 [ %0, edge.0 ], [ 0, if.then ]
br label while.cond
exit:
ret 
}


define internal @TestNestedWhileLoops void() {
entry:
br label while.cond
while.cond:
%0 = phi i64 [ 0, entry ], [ %1, while.end ]
%2 = phi i64 [ 0, entry ], [ %3, while.end ]
%4 = icmp slt i64 %0, 3
br i8 %4, label while.body, label while.end1
while.body:
br label while.cond1
while.end1:
%5 = icmp eq i64 %0, 3
call i8 %5, @Assert
%6 = icmp eq i64 %2, 2
call i8 %6, @Assert
br label exit
while.cond1:
%3 = phi i64 [ %2, while.body ], [ %7, while.body1 ]
%8 = icmp slt i64 %3, 2
br i8 %8, label while.body1, label while.end
while.body1:
%9 = alloca ptr
store i64 %3, ptr %9
%7 = add i64 %3, 1
br label while.cond1
while.end:
%10 = alloca ptr
store i64 %0, ptr %10
%1 = add i64 %0, 1
br label while.cond
exit:
ret 
}


define internal @TestWhileLoopWithBreak void() {
entry:
br label while.cond
while.cond:
%0 = phi i64 [ 0, entry ], [ %1, if.end ]
%2 = phi i64 [ 1, entry ], [ %3, if.end ]
br label while.body
while.body:
%1 = add i64 %0, %2
%4 = alloca ptr
store i64 %2, ptr %4
%3 = add i64 %2, 1
%5 = icmp sle i64 %3, 5
br i8 %5, label if.end, label while.end
while.end:
