import std.assert;

class MathHelper<T>
{
	public T Double(T x)
	{
		return Multiply(x, 2);
	}

	public T Triple(T x)
	{
		return Multiply(x, 3);
	}

	public T Multiply(T a, T b)
	{
		return a * b;
	}
};

public int main()
{
	MathHelper<int> m;
	Assert(m.Double(5) == 10);
	Assert(m.Triple(4) == 12);
	Assert(m.Multiply(3, 7) == 21);

	MathHelper<float> mf;
	Assert(mf.Double(2.5) == 5.0);
	return 0;
}
