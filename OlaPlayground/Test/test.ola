import std.assert;

class Animal
{
    Animal() { this.legs = 0; }
    Animal(int l) { this.legs = l; }
    public int GetLegs() const { return this.legs; }
    public int Speak() const virtual { return 0; }
    public int legs;
};

class Dog : Animal
{
    Dog()
    {
        super();
        this.barkVolume = 0;
    }
    Dog(int l, int bv)
    {
        super(l);
        this.barkVolume = bv;
    }
    public int Speak() const virtual { return this.barkVolume; }
    public int barkVolume;
};

public int main()
{
    Dog* d = new Dog(4, 10);
    Animal* a = d;
    Assert(a->GetLegs() == 4);
    Assert(a->Speak() == 10);
    Assert((*a).GetLegs() == 4);
    Assert((*d).Speak() == 10);
    delete d;
    return 0;
}
