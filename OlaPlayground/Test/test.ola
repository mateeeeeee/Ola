import std.assert;

int SumArray(int[5] arr)
{
	int s = 0;
	for (int i = 0; i < 5; i++)
	{
		s += arr[i];
	}
	return s;
}

void ModifyArrayByValue(int[3] arr)
{
	arr[0] = 999;
}

void TestArrayPassByValue()
{
	int[5] arr = {2, 4, 6, 8, 10};
	int s = SumArray(arr);
	Assert(s == 30);

	int[3] orig = {1, 2, 3};
	ModifyArrayByValue(orig);
	Assert(orig[0] == 1);
}

void ZeroArray(ref int[5] arr)
{
	for (int i = 0; i < 5; i++)
	{
		arr[i] = 0;
	}
}

void TestArrayPassByRef()
{
	int[5] arr = {1, 2, 3, 4, 5};
	ZeroArray(arr);
	for (int i = 0; i < 5; i++)
	{
		Assert(arr[i] == 0);
	}
}

void ReverseArray(ref int[5] arr)
{
	int left = 0;
	int right = 4;
	while (left < right)
	{
		int tmp = arr[left];
		arr[left] = arr[right];
		arr[right] = tmp;
		left++;
		right--;
	}
}

void TestArrayReverse()
{
	int[5] arr = {1, 2, 3, 4, 5};
	ReverseArray(arr);
	Assert(arr[0] == 5);
	Assert(arr[1] == 4);
	Assert(arr[2] == 3);
	Assert(arr[3] == 2);
	Assert(arr[4] == 1);
}

void TestArrayBubbleSort()
{
	int[5] arr = {5, 3, 1, 4, 2};
	for (int i = 0; i < 5; i++)
	{
		for (int j = 0; j < 4 - i; j++)
		{
			if (arr[j] > arr[j + 1])
			{
				int tmp = arr[j];
				arr[j] = arr[j + 1];
				arr[j + 1] = tmp;
			}
		}
	}
	Assert(arr[0] == 1);
	Assert(arr[1] == 2);
	Assert(arr[2] == 3);
	Assert(arr[3] == 4);
	Assert(arr[4] == 5);
}

void TestArrayCountMatches()
{
	int[8] arr = {1, 3, 5, 3, 7, 3, 9, 3};
	int count = 0;
	for (int i = 0; i < 8; i++)
	{
		if (arr[i] == 3) count++;
	}
	Assert(count == 4);
}

void TestArrayPrefixSum()
{
	int[5] arr = {1, 2, 3, 4, 5};
	for (int i = 1; i < 5; i++)
	{
		arr[i] += arr[i - 1];
	}
	Assert(arr[0] == 1);
	Assert(arr[1] == 3);
	Assert(arr[2] == 6);
	Assert(arr[3] == 10);
	Assert(arr[4] == 15);
}

public int main()
{
	TestArrayPassByValue();
	TestArrayPassByRef();
	TestArrayReverse();
	TestArrayBubbleSort();
	TestArrayCountMatches();
	TestArrayPrefixSum();
	return 0;
}
