{
    "version": "0.2.0",
    "configurations": [
        // ----------------------------------------------------------------
        // Compiler driver
        // ----------------------------------------------------------------
        {
            "name": "Debug Ola Compiler",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Ola",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Release Ola Compiler",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/Ola",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        {
            "name": "Debug Ola Compiler (current file)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Ola",
            "args": ["${file}"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Release Ola Compiler (current file)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/Ola",
            "args": ["${file}"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        // ----------------------------------------------------------------
        // OlaTests — unit tests (Lexer, Parser, Sema, IR, IR Passes)
        // ----------------------------------------------------------------
        {
            "name": "Tests: Unit (Debug)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Unit (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaTests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        {
            "name": "Tests: Lexer",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Lexer.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Parser",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Parser.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Interpreter",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Interpreter.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Sema",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Sema.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: IR Passes",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=DCE.*:ConstantPropagation.*:ArithmeticReduction.*:SimplifyCFG.*:Mem2Reg.*:TailRecursionElimination.*:GlobalDCE.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        // ----------------------------------------------------------------
        // OlaTestsE2E — custom backend E2E tests
        // ----------------------------------------------------------------
        {
            "name": "Tests: E2E (Debug)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTestsE2E",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: E2E (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaTestsE2E",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        // ----------------------------------------------------------------
        // OlaTestsInterpreter — interpreter E2E tests
        // ----------------------------------------------------------------
        {
            "name": "Tests: E2E Interpreter (Debug)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTestsInterpreter",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: E2E Interpreter (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaTestsInterpreter",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        // ----------------------------------------------------------------
        // OlaTestsLLVM — LLVM backend E2E tests
        // ----------------------------------------------------------------
        {
            "name": "Tests: E2E LLVM (Debug)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTestsLLVM",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: E2E LLVM (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaTestsLLVM",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        // ----------------------------------------------------------------
        // Playground
        // ----------------------------------------------------------------
        {
            "name": "Debug OlaPlayground",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaPlayground",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Release OlaPlayground",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaPlayground",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        }
    ]
}
