{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Ola Compiler",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Ola",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Release Ola Compiler",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/Ola",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        {
            "name": "Debug Ola Compiler (current file)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Ola",
            "args": ["${file}"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Release Ola Compiler (current file)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/Ola",
            "args": ["${file}"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        {
            "name": "Tests: Unit (Debug)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Unit (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/bin/OlaTests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Release)"
        },
        {
            "name": "Tests: Lexer",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Lexer.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Parser",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Parser.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Interpreter",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Interpreter.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Sema",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=Sema.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: IR Passes",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=DCE.*:ConstantPropagation.*:ArithmeticReduction.*:SimplifyCFG.*:Mem2Reg.*:TailRecursionElimination.*:GlobalDCE.*:CSE.*:GVN.*:FunctionInliner.*:LICM.*:SROA.*:CriticalEdgeSplitting.*:IPCP.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Machine IR",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=MachineOperand.*:MachineInstruction.*:MachineBasicBlock.*:MachineFunction.*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Ola (Debug)"
        },
        {
            "name": "Tests: Register Allocation",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/OlaTests",
            "args": ["--gtest_filter=InterferenceGraph.*:LiveInterval.*"],
            "cwd": "${workspaceFolder}",
